{
  "name": "ecom-boilerplate",
  "version": "0.0.1",
  "description": "Aura Turborepo workspace",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@8.15.8",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "pnpm --dir apps/backend format",
    "start": "pnpm --dir apps/backend start",
    "start:dev": "pnpm --dir apps/backend start:dev",
    "start:debug": "pnpm --dir apps/backend start:debug",
    "start:prod": "pnpm --dir apps/backend start:prod",
    "backend:build": "pnpm --dir apps/backend build",
    "backend:dev": "pnpm --dir apps/backend dev",
    "backend:lint": "pnpm --dir apps/backend lint",
    "backend:test": "pnpm --dir apps/backend test -- --runInBand",
    "backend:test:e2e": "pnpm --dir apps/backend test:e2e",
    "backend:test:cov": "pnpm --dir apps/backend test:cov",
    "storefront:dev": "pnpm --dir apps/storefront dev",
    "storefront:build": "pnpm --dir apps/storefront build",
    "storefront:start": "pnpm --dir apps/storefront start",
    "storefront:lint": "pnpm --dir apps/storefront lint",
    "storefront:test": "pnpm --dir apps/storefront test",
    "seed": "pnpm --dir apps/backend seed",
    "db:up": "docker compose up -d postgres redis rustfs",
    "db:down": "docker compose down",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f api",
    "prisma:generate": "pnpm --dir apps/backend prisma:generate",
    "prisma:migrate:dev": "pnpm --dir apps/backend prisma:migrate:dev",
    "prisma:studio": "pnpm --dir apps/backend prisma:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.0.14",
    "typescript-eslint": "^8.20.0"
  }
}
