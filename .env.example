# Application
NODE_ENV=development
PORT=3000
APP_NAME=Aura-Core
APP_VERSION=0.0.1
API_PREFIX=api/v1
LOG_LEVEL=debug
STRICT_HEALTH_CHECKS=false

# Database / Cache
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/aura_core?schema=public"
REDIS_URL="redis://localhost:56379"
CART_TTL_SECONDS=604800

# Authentication
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="http://localhost:3000/checkout/success"
STRIPE_CANCEL_URL="http://localhost:3000/checkout/cancel"

# S3 / RustFS
S3_ENDPOINT="http://localhost:9100"
S3_REGION="us-east-1"
S3_BUCKET="product-images"
S3_ACCESS_KEY="rustfsadmin"
S3_SECRET_KEY="rustfsadmin"
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL="http://localhost:9100/product-images"
PRODUCT_MEDIA_MAX_BYTES=5242880
